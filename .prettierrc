{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "overrides": [
    {
      "files": "*.mdx",
      "options": {
        "proseWrap": "always",
        "printWidth": 75,
        "bracketSpacing": false
      }
    }
  ],
  "plugins": ["prettier-plugin-astro"]
}
