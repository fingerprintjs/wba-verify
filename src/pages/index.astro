---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav/Nav.astro'
import Terminal from '../components/Terminal.svelte'

import FingerprintLogo from '../assets/images/fingerprint_logo.png'

import '../styles/global.css'
---

<Layout>
  <Nav />
  <main role="main">
    <h1 class='sr-only'>Web Bot Authentication Verification</h1>
    <Terminal client:load />
    <div id='logo'>
      <hr />
      <img src={FingerprintLogo.src} width='128' alt='Fingerprint Logo' class='flex' />
    </div>
  </main>
</Layout>

<script>
  import { GITHUB_REPO_URL } from '../constants.js'
  console.log(
    `Hi there, welcome to %cFingerprint WBAV%c :) \n\nGitHub:       ${GITHUB_REPO_URL} \n\n%cWe're hiring: https://fingerprint.com/careers`,
    'font-weight: bold;',
    'font-weight: normal;',
    'color: #f35b22;'
  )
</script>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: var(--bezel);
    max-width: 96rem;
    width: 100%;
    height: 100%;
    margin: 0 auto;
    padding: var(--bezel);
    padding-top: calc(var(--bezel) * 2 + 33px);
  }

  #logo {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 16px;
    width: 100%;
    height: 32px;
    padding: 0 calc(var(--bezel) * 2);
    padding-right: 18px;
  }

  #logo hr {
    width: 100%;
    height: 16px;
    background: repeating-linear-gradient(
      to bottom,
      hsl(var(--color-gray-4)) 0px,
      hsl(var(--color-gray-4)) 1px,
      rgba(255, 255, 255, 0.6) 1px,
      rgba(255, 255, 255, 0.6) 2px,
      transparent 2px,
      transparent 6px
    );
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    #logo {
      display: none;
    }
  }
</style>
