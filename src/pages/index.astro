---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav/Nav.astro'
import Terminal from '../components/Terminal.svelte'

import FingerprintLogo from '../assets/images/fingerprint_logo.png'

import '../styles/global.css'
---

<Layout>
  <Nav />
  <main>
    <h1 class="sr-only">Web Bot Authentication Verification</h1>
    <Terminal client:load />
    <div id="logo">
      <hr />
      <img src={FingerprintLogo.src} width="128" alt="Fingerprint Logo" class="flex" />
    </div>
  </main>
  <!-- Background texture -->
  <svg id="texture" aria-hidden="true">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency=".8" numOctaves="2" stitchTiles="stitch"
      ></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)"></rect>
  </svg>
</Layout>

<script>
  console.log(
    "Hi there, welcome to %cFingerprint WBAV%c. \n\nGitHub:       https://github.com/fingerprintjs/wba-verify \n\n%cWe're hiring: https://fingerprint.com/careers",
    'font-weight: bold;',
    'font-weight: normal;',
    'color: #f35b22;'
  )
</script>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: var(--bezel);
    max-width: 96rem;
    width: 100%;
    height: 100%;
    margin: 0 auto;
    padding: var(--bezel);
    padding-top: calc(var(--bezel) * 2 + 33px);
  }

  #logo {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 16px;
    width: 100%;
    height: 32px;
    padding: 0 calc(var(--bezel) * 2);
    padding-right: 18px;
  }

  #logo hr {
    width: 100%;
    height: 16px;
    background: repeating-linear-gradient(
      to bottom,
      hsl(var(--color-gray-4)) 0px,
      hsl(var(--color-gray-4)) 1px,
      rgba(255, 255, 255, 0.6) 1px,
      rgba(255, 255, 255, 0.6) 2px,
      transparent 2px,
      transparent 6px
    );
  }

  #texture {
    bottom: 0;
    height: 100%;
    left: 0;
    opacity: 0.25;
    pointer-events: none;
    position: fixed;
    width: 100%;
    z-index: -1;
    filter: contrast(200%);
  }
</style>
