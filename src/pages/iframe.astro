---
import iframeCss from '../iframe/styles.css?inline'
import tokensCss from '../styles/tokens.css?inline'
import IframeBoot from '../components/IframeBoot.svelte'
---

<!doctype html>
<html lang='en' data-wbav-boot='pending'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>WBAV</title>

    <style>
      /* Default visible state */
      html {
        visibility: visible;
        opacity: 1;
      }

      /* Hide only while boot is pending */
      html[data-wbav-boot='pending'] {
        visibility: hidden;
        opacity: 0;
      }
    </style>

    <style is:inline set:html={`${tokensCss}\n${iframeCss}`}></style>
  </head>

  <body>
    <div class='terminal'>
      <div class='terminal__inner'>
        <h1 class='sr-only'>Web Bot Auth Verification v0.0.1</h1>
        <div class='terminal__figlet' aria-hidden='true'></div>
        <pre
          class='terminal__boot'><b style="color: var(--ansi-dim)">Test your bot?&nbsp;</b>[Y]/n<span class="cursor" /></pre>
      </div>
      <div class='static' aria-hidden='true'></div>
    </div>

    <IframeBoot client:load />
  </body>
</html>
