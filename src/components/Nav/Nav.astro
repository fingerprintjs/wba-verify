---
import NavActions from './NavActions.svelte'
import { FINGERPRINT_HOMEPAGE_URL, GITHUB_REPO_URL, SUBMIT_BOT_URL } from '../../constants.js'
---

<nav class='navbar'>
  <ul class='navbar-nav mr-auto'>
    <li><a href={FINGERPRINT_HOMEPAGE_URL}>Fingerprint.com</a></li>
    <li class='hidden md:inline'><a href={GITHUB_REPO_URL}>GitHub</a></li>
    <!-- TODO: add docs link once it is live -->
    <!-- <li class='hidden md:inline'><a href='/'>Docs</a></li> -->
    <li class='hidden md:inline'><a href={SUBMIT_BOT_URL}>Submit your bot</a></li>
    <li class='md:hidden'>
      <a href={GITHUB_REPO_URL} aria-label='github.com'>
        <svg
          aria-hidden='true'
          width='12'
          height='12'
          viewBox='0 0 24 24'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'
        >
          <path
            d='M10 22H8V20H4V18H8V16H10V22ZM16 22H14V16H16V22ZM4 18H2V16H4V18ZM8 16H4V14H8V16ZM20 16H16V14H20V16ZM4 14H2V6H4V14ZM22 14H20V6H22V14ZM8 4H6V6H4V2H8V4ZM16 6H8V4H16V6ZM20 6H18V4H16V2H20V6Z'
            fill='currentColor'></path>
        </svg>
      </a>
    </li>
  </ul>
  <!-- interactive island -->
  <NavActions client:load />
</nav>

<style>
  .navbar {
    position: fixed;
    display: flex;
    align-items: center;
    width: 100%;
    height: 48px;
    padding: 0 calc(var(--bezel) + 12px);
  }

  .navbar-nav {
    list-style: none;
    display: flex;
    flex-direction: row;
    gap: 2px;
  }

  li:focus-within {
    z-index: 1;
  }

  li:first-of-type a {
    border-top-left-radius: 2px;
    border-bottom-left-radius: 2px;
  }
  li:last-of-type a {
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
  }

  li:first-of-type .btn {
    border-radius: 2px 0 0 2px;
  }
  li:last-of-type .btn {
    border-radius: 0 2px 2px 0;
  }

  a {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 0 6px;
    width: fit-content;
    height: 24px;

    background-color: hsl(var(--color-gray-3));

    color: hsl(var(--color-gray-10));
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    text-decoration: none;
  }

  a:hover {
    background-color: hsl(var(--color-gray-4));
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .navbar {
      padding: 0 calc(var(--bezel) + 3px);
    }
  }
</style>
